# =============================================================================
# Ethos Frontend - Exemplo de variáveis de ambiente
# =============================================================================
# Copie este arquivo para `.env` e ajuste os valores conforme o ambiente.
# Todas as variáveis expostas ao client devem ser prefixadas com `VITE_`.
# Os valores abaixo são fictícios e servem apenas como referência.
# =============================================================================

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
# URL base da API do backend Ethos (sem barra no final).
VITE_API_URL=https://api.exemplo.com

# -----------------------------------------------------------------------------
# Modo de manutenção
# -----------------------------------------------------------------------------
# Quando "true", a aplicação redireciona o usuário para a página /maintenance.
VITE_MAINTENANCE_MODE=false

# Texto detalhando o motivo/contexto da manutenção exibido no modal "Saiba Mais".
# Caso não definido, um texto genérico é exibido como fallback.
VITE_MAINTENANCE_DETAILS="Estamos atualizando nossos servidores para melhorar a performance da plataforma."

# Estimativa de retorno do serviço (texto livre).
VITE_MAINTENANCE_ESTIMATE="Aproximadamente 2 horas"

# Contato de suporte exibido no modal de manutenção (e-mail, telefone, etc.).
VITE_MAINTENANCE_CONTACT="suporte@exemplo.com"
